{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "sh \"${PLUGIN_ROOT}/bin/ponytail\" activate",
        "powershell": "& \"$env:PLUGIN_ROOT\\bin\\ponytail-windows-amd64.exe\" activate",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "sh \"${PLUGIN_ROOT}/bin/ponytail\" track",
        "powershell": "& \"$env:PLUGIN_ROOT\\bin\\ponytail-windows-amd64.exe\" track",
        "timeoutSec": 5
      }
    ]
  }
}
